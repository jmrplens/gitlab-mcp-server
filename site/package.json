{
  "name": "gitlab-mcp-server-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "eslint": "eslint .",
    "html-validate": "html-validate 'dist/**/*.html'",
    "htmlhint": "htmlhint 'dist/**/*.html'",
    "pa11y": "astro preview & sleep 3 && pa11y-ci; EXIT=$?; kill %1 2>/dev/null; exit $EXIT",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run check && pnpm run eslint && pnpm run format:check && pnpm run html-validate && pnpm run htmlhint",
    "test:a11y": "pnpm run pa11y",
    "analyze": "pnpm run build && pnpm run lint"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/starlight": "^0.38.3",
    "astro": "^6.1.5",
    "astro-mermaid": "^2.0.1",
    "mermaid": "^11.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "html-validate": "^10.12.1",
    "htmlhint": "^1.9.2",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.2",
    "serve": "^14.2.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "yaml": ">=2.8.3"
    }
  }
}
