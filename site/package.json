{
  "name": "gitlab-mcp-server-docs",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "find dist -name '*.html' -exec sed -i 's/[[:space:]]*$//' {} +",
    "preview": "astro preview",
    "check": "astro check",
    "eslint": "eslint .",
    "html-validate": "html-validate 'dist/**/*.html'",
    "htmlhint": "htmlhint 'dist/**/*.html'",
    "pa11y": "astro preview & sleep 3 && pa11y-ci; EXIT=$?; kill %1 2>/dev/null; exit $EXIT",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run check && pnpm run eslint && pnpm run format:check && pnpm run html-validate && pnpm run htmlhint",
    "test:a11y": "pnpm run pa11y",
    "analyze": "pnpm run build && pnpm run lint"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/starlight": "^0.38.4",
    "astro": "^6.1.9",
    "astro-mermaid": "^2.0.1",
    "mermaid": "^11.14.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "html-validate": "^10.13.1",
    "htmlhint": "^1.9.2",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "starlight-links-validator": "^0.24.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "yaml": ">=2.8.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": ">=6.0.0"
      }
    }
  }
}
