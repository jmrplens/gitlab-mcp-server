# Environment variables (secrets)
.env

# GPG secret keys (NEVER commit private keys)
keys/*.secret.asc

# Go build artifacts
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Local CLI binaries from cmd/* (built by `go build ./cmd/<name>`)
/audit_metrics
/audit_output
/audit_test_names
/audit_tokens
/audit_tools
/add_docs
/find_dupes
/gen_docker_tools
/gen_llms
/gen_readme
/gitlab-mcp-server

# Go workspace lock (Go 1.18+, only relevant if go.work is added)
go.work.sum

# Profiling output
*.prof
*.pprof
*.trace
cpu.out
mem.out

# Go test artifacts
*.test
*.out
cov-*
coverage.txt

# Temporary lint/debug reports
golangci-report*.txt
lint_err.txt
wizard_build.txt
wizard_err.txt
wizard_test_err.txt
coverage.html
coverage/
cov_*/
cover_*
coverage_*
!coverage_test.go

# Temporary output/result files
*-results.txt
*-output.txt
test-result.txt
crossbuild.txt
NUL

# Temporary GraphQL/debug files
gql*.json
graphql_query.json
gql_result.txt

# Temporary lint/analysis logs
lint-remaining.txt
golangci-remaining.txt
modernize-output.txt

# Go vendor (optional)
# vendor/

# Implementation plans (local working notes)
plan/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/mcp.json
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# E2E Docker ephemeral mode (auto-generated by test/e2e/scripts/setup-gitlab.sh)
.env.docker

# Astro Starlight
site/node_modules/
site/dist/
site/.astro/
public/
.scannerwork/
.sonarlint/
image.png
